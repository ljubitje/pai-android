# PAI Android — user .bashrc (v7)
# Sourced by bash for interactive non-login shells,
# and by /etc/profile for interactive login shells.

# If not running interactively, don't do anything
case $- in *i*) ;; *) return;; esac

# If not bash, bail out — sh doesn't support shopt, PS1 escapes, etc.
[ -z "$BASH_VERSION" ] && return

# ── Prompt ──
PS1='\[\e[1;34m\]pai\[\e[0m\]:\[\e[1;36m\]\w\[\e[0m\]\$ '

# ── History ──
HISTSIZE=5000
HISTFILESIZE=10000
HISTCONTROL=ignoreboth:erasedups
shopt -s histappend

# ── Shell options ──
shopt -s checkwinsize
shopt -s globstar 2>/dev/null

# ── Environment ──
export TMPDIR="$PREFIX/tmp"
# Node.js global module resolution (for bun polyfill and other global pkgs)
export NODE_PATH="$PREFIX/lib/node_modules"
export GIT_EXEC_PATH="$PREFIX/libexec/git-core"
export GIT_TEMPLATE_DIR="$PREFIX/share/git-core/templates"
export GIT_SSL_CAINFO="$PREFIX/etc/tls/cert.pem"
[[ -d "${XDG_DATA_HOME:-$HOME/.local}/bin" ]] && export PATH="${XDG_DATA_HOME:-$HOME/.local}/bin:$PATH"
# Bun (installed by PAI's install.sh into PREFIX for execute permission)
export BUN_INSTALL="$PREFIX/bun"
[[ -d "$BUN_INSTALL/bin" ]] && export PATH="$BUN_INSTALL/bin:$PATH"

# ── Aliases ──
alias ls='ls --color=auto'
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias grep='grep --color=auto'
alias ..='cd ..'
alias ...='cd ../..'

# ── pkg shorthand ──
alias update='pkg update'
alias upgrade='pkg upgrade'
alias install='pkg install'
alias search='pkg search'

# ── PAI ──
# PAI CLI alias
alias pai='bun "$HOME/.claude/PAI/Tools/pai.ts"'

# Claude Code wrapper (bind-mount /tmp for Claude Code compatibility)
if command -v proot &>/dev/null && command -v claude &>/dev/null; then
    alias claude='proot -b "$PREFIX/tmp:/tmp" claude'
fi
