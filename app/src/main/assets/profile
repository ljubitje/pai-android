# PAI Android — user .profile (v3)
# Sourced by bash for login shells when /etc/profile is not found.

# Source system profile if it exists at our prefix
if [ -n "$PREFIX" ] && [ -r "$PREFIX/etc/profile" ]; then
    . "$PREFIX/etc/profile"
elif [ -r "$HOME/.bashrc" ]; then
    # Fallback: source .bashrc directly
    . "$HOME/.bashrc"
fi
